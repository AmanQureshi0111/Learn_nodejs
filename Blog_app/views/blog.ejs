<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
        <title>
            <%= blog.title %>
        </title>
</head>

<body>
    <%- include('./partials/nav') %>
        <div class="container mt-4">
            <h1 class="mb-3">
                <%= blog.title %>
            </h1>
            <% if (blog.coverImageURL) { %>
                <img src="<%= blog.coverImageURL %>" class="img-fluid rounded mb-3" alt="Blog cover image">
                <% } %>

                    <% const authorProfileImage=(blog.createdBy?.profileImageURL || '/images/default.png'
                        ).replace('../public', '' ); %>
                        <p class="text-muted">
                            By <img src="<%= authorProfileImage %>" width="20px" />
                            <%= blog.createdBy?.fullName || 'Unknown author' %>
                        </p>
                        <pre><%= blog.body %></pre>
        </div>
        <div class="container mt-3">
            <h1>Comments (<%=comments.length %>)
            </h1>
            <% if (locals.user){%>
                <form action="/blog/comment/<%= blog._id %>" method="post">
                    <div class="mb-3">
                        <input type="text" class="form-control" name="content" aria-describedby="content"
                            placeholder="Enter your comment" required>
                        <button class="btn btn-sm btn-primary" type="submit">Add</button>
                    </div>
                </form>

                <%} %>
                    <div class="mt-3">
                        <% comments.forEach(comment=> { %>
                            <% const commentProfileImage=(comment.createdBy?.profileImageURL || '/images/default.png'
                                ).replace('../public', '' ); %>
                                <div>
                                    <img src="<%= commentProfileImage %>" width="20px" />
                                    <%= comment.createdBy?.fullName || 'Unknown author' %>:
                                        <pre><%= comment.content %></pre>
                                </div>
                                <%}) %>
                    </div>
        </div>
        <%- include('./partials/script') %>
</body>

</html>